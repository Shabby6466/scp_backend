generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  DIRECTOR
  BRANCH_DIRECTOR
  TEACHER
  STUDENT
  PARENT
}

enum StaffPosition {
  ED_DIRECTOR
  LEAD_TEACHER
  ASSISTANT_TEACHER
  PARAPROFESSIONAL
}

enum RenewalPeriod {
  NONE
  ANNUAL
  BIENNIAL
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// ─────────────────────────────────────────────────────────────
// User + Authority Chain
//
// ADMIN
//  └── DIRECTOR  (school-level)
//       └── BRANCH_DIRECTOR  (branch-level)
//            ├── TEACHER
//            └── STUDENT  ←──  PARENT (lateral, via StudentParent)
// ─────────────────────────────────────────────────────────────

model User {
  id                   String             @id @default(cuid())
  email                String             @unique
  password             String?
  name                 String?
  phone                String?
  role                 UserRole
  authorities          UserRole[]         @default([])
  schoolId             String?
  branchId             String?
  assignedById         String?
  staffPosition        StaffPosition?
  staffClearanceActive Boolean            @default(false)
  emailVerifiedAt      DateTime?
  deletedAt            DateTime?
  deletedBy            String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  school               School?            @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  branch               Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  assignedBy           User?              @relation("AuthorityAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  assignedUsers        User[]             @relation("AuthorityAssignedBy")

  uploadedDocuments    Document[]         @relation("UploadedBy")
  ownerDocuments       Document[]         @relation("DocumentOwner")
  reviewedDocuments    Document[]         @relation("DocumentReviewer")

  createdDocumentTypes         DocumentType[]       @relation("DocumentTypeCreator")
  requiredDocTypes             DocumentType[]       @relation("UserRequiredDocTypes")
  createdComplianceCategories  ComplianceCategory[] @relation("ComplianceCategoryCreator")

  studentLinks         StudentParent[]    @relation("StudentSide")
  parentLinks          StudentParent[]    @relation("ParentSide")

  directorProfile       DirectorProfile?
  branchDirectorProfile BranchDirectorProfile?
  teacherProfile        TeacherProfile?
  studentProfile        StudentProfile?
  parentProfile         ParentProfile?
  eligibilityProfile    TeacherEligibilityProfile?

  ownedComplianceReqs   ComplianceRequirement[] @relation("ComplianceOwner")
  createdComplianceReqs ComplianceRequirement[] @relation("ComplianceCreator")

  sentInvitations       Invitation[]       @relation("InvitationSender")
  auditEvents           AuditEvent[]

  @@index([role])
  @@index([schoolId])
  @@index([branchId])
  @@index([assignedById])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────
// Parent ↔ Student link (many-to-many)
// A parent can have multiple children across schools.
// A student can have multiple parents/guardians.
// ─────────────────────────────────────────────────────────────

model StudentParent {
  id         String   @id @default(cuid())
  studentId  String
  parentId   String
  relation   String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  student    User     @relation("StudentSide", fields: [studentId], references: [id], onDelete: Cascade)
  parent     User     @relation("ParentSide", fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([studentId, parentId])
  @@index([parentId])
  @@index([studentId])
}

// ─────────────────────────────────────────────────────────────
// Organization
// ─────────────────────────────────────────────────────────────

model School {
  id                  String    @id @default(cuid())
  name                String
  email               String?
  phone               String?
  address             String?
  city                String?
  state               String?
  zipCode             String?
  website             String?
  licenseNumber       String?
  certificationNumber String?
  minAge              Int?
  maxAge              Int?
  totalCapacity       Int?
  primaryColor        String?
  logoUrl             String?
  isApproved          Boolean   @default(false)
  approvedAt          DateTime?
  approvedBy          String?
  deletedAt           DateTime?
  deletedBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  users                  User[]
  branches               Branch[]
  documentTypes          DocumentType[]
  complianceCategories   ComplianceCategory[]
  teacherPositions       TeacherPosition[]
  eligibilityProfiles    TeacherEligibilityProfile[]
  inspectionTypes        InspectionType[]
  complianceRequirements ComplianceRequirement[]
  certificationRecords   CertificationRecord[]
  invitations            Invitation[]
}

model Branch {
  id            String    @id @default(cuid())
  name          String
  schoolId      String
  address       String?
  city          String?
  state         String?
  zipCode       String?
  phone         String?
  email         String?
  minAge        Int?
  maxAge        Int?
  totalCapacity Int?
  isPrimary     Boolean   @default(false)
  isActive      Boolean   @default(true)
  notes         String?
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  users         User[]
  documentTypes DocumentType[]

  @@index([schoolId])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────
// Document Types & Documents
// ─────────────────────────────────────────────────────────────

model DocumentType {
  id                   String              @id @default(cuid())
  name                 String
  targetRole           UserRole
  category             String?
  description          String?
  isMandatory          Boolean             @default(true)
  isActive             Boolean             @default(true)
  renewalPeriod        RenewalPeriod       @default(NONE)
  sortOrder            Int                 @default(0)
  appliesToAgeMin      Int?
  appliesToAgeMax      Int?
  schoolId             String?
  branchId             String?
  complianceCategoryId String?
  createdById          String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  school               School?             @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  branch               Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  complianceCategory   ComplianceCategory? @relation(fields: [complianceCategoryId], references: [id], onDelete: SetNull)
  createdBy            User                @relation("DocumentTypeCreator", fields: [createdById], references: [id], onDelete: Restrict)
  requiredUsers        User[]              @relation("UserRequiredDocTypes")
  documents            Document[]

  @@index([schoolId])
  @@index([branchId])
  @@index([complianceCategoryId])
  @@index([targetRole])
  @@index([createdById])
}

model Document {
  id              String         @id @default(cuid())
  ownerUserId     String
  documentTypeId  String
  uploadedById    String
  s3Key           String
  fileName        String
  mimeType        String
  sizeBytes       Int
  status          DocumentStatus @default(PENDING)
  notes           String?
  issuedAt        DateTime?
  expiresAt       DateTime?
  verifiedAt      DateTime?
  reviewedAt      DateTime?
  reviewedById    String?
  rejectionReason String?
  deletedAt       DateTime?
  deletedBy       String?
  createdAt       DateTime       @default(now())

  ownerUser       User           @relation("DocumentOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  uploadedBy      User           @relation("UploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  reviewedBy      User?          @relation("DocumentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  documentType    DocumentType   @relation(fields: [documentTypeId], references: [id], onDelete: Restrict)

  @@index([ownerUserId])
  @@index([documentTypeId])
  @@index([uploadedById])
  @@index([reviewedById])
  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([deletedAt])
}

model ComplianceCategory {
  id          String         @id @default(cuid())
  name        String
  slug        String
  description String?
  icon        String?
  sortOrder   Int            @default(0)
  schoolId    String
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy     User           @relation("ComplianceCategoryCreator", fields: [createdById], references: [id], onDelete: Restrict)
  documentTypes DocumentType[]

  @@unique([schoolId, slug])
  @@index([schoolId])
}

// ─────────────────────────────────────────────────────────────
// Role-Specific Profiles
// ─────────────────────────────────────────────────────────────

model DirectorProfile {
  userId      String   @id
  officePhone String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BranchDirectorProfile {
  userId           String    @id
  branchStartDate  DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TeacherProfile {
  userId                String           @id
  subjectArea           String?
  employeeCode          String?
  joiningDate           DateTime?
  phone                 String?
  hireDate              DateTime?
  employmentStatus      EmploymentStatus @default(ACTIVE)
  certificationType     String?
  certificationExpiry   DateTime?
  backgroundCheckDate   DateTime?
  backgroundCheckExpiry DateTime?
  positionId            String?
  notes                 String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  position              TeacherPosition? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@index([positionId])
}

model StudentProfile {
  userId        String    @id
  firstName     String?
  lastName      String?
  dateOfBirth   DateTime?
  gradeLevel    String?
  rollNumber    String?
  guardianName  String?
  guardianPhone String?
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ParentProfile {
  userId    String   @id
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// Teacher Eligibility & Positions
// ─────────────────────────────────────────────────────────────

model TeacherEligibilityProfile {
  id                 String    @id @default(cuid())
  userId             String    @unique
  schoolId           String
  educationLevel     String?
  educationField     String?
  totalCredits       Int?
  eceCredits         Int?
  yearsExperience    Int?
  resumePath         String?
  cdaCredential      Boolean   @default(false)
  stateCertification Boolean   @default(false)
  firstAidCertified  Boolean   @default(false)
  cprCertified       Boolean   @default(false)
  languages          String?
  notes              String?
  aiAnalysis         String?
  aiAnalyzedAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  school             School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

model TeacherPosition {
  id                 String   @id @default(cuid())
  schoolId           String
  name               String
  description        String?
  minEducationLevel  String?
  minCredits         Int?
  minEceCredits      Int?
  minYearsExperience Int?
  requiresCda        Boolean  @default(false)
  requiresStateCert  Boolean  @default(false)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  school             School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teachers           TeacherProfile[]

  @@index([schoolId])
}

// ─────────────────────────────────────────────────────────────
// Compliance & Inspections
// ─────────────────────────────────────────────────────────────

model InspectionType {
  id           String    @id @default(cuid())
  schoolId     String
  name         String
  description  String?
  frequency    String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  requirements ComplianceRequirement[]

  @@index([schoolId])
}

model ComplianceRequirement {
  id               String          @id @default(cuid())
  schoolId         String
  inspectionTypeId String?
  title            String
  description      String?
  frequency        String?
  intervalValue    Int?
  riskLevel        String?
  status           String          @default("pending")
  dueDate          DateTime?
  nextDueDate      DateTime?
  lastCompletedAt  DateTime?
  evidenceRequired Boolean         @default(false)
  requiresReview   Boolean         @default(false)
  ownerUserId      String?
  createdById      String?
  tags             String[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  school           School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  inspectionType   InspectionType? @relation(fields: [inspectionTypeId], references: [id], onDelete: SetNull)
  owner            User?           @relation("ComplianceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdBy        User?           @relation("ComplianceCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([ownerUserId])
  @@index([status])
  @@index([dueDate])
}

// ─────────────────────────────────────────────────────────────
// Certifications
// ─────────────────────────────────────────────────────────────

model CertificationType {
  id                    String   @id @default(cuid())
  name                  String
  description           String?
  appliesTo             String?
  defaultValidityMonths Int?
  evidenceTypes         String[]
  tags                  String[]
  isSystemDefault       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  records               CertificationRecord[]
}

model CertificationRecord {
  id                  String            @id @default(cuid())
  schoolId            String
  certificationTypeId String
  appliesTo           String?
  subjectId           String?
  subjectName         String?
  issuedDate          DateTime?
  expiryDate          DateTime?
  status              String            @default("active")
  ownerUserId         String?
  notes               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  school              School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  certificationType   CertificationType @relation(fields: [certificationTypeId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([certificationTypeId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// Invitations
// ─────────────────────────────────────────────────────────────

model Invitation {
  id          String           @id @default(cuid())
  schoolId    String
  branchId    String?
  email       String
  role        UserRole
  token       String           @unique
  status      InvitationStatus @default(PENDING)
  sentById    String?
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())

  school      School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sentBy      User?            @relation("InvitationSender", fields: [sentById], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([email])
  @@index([token])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// Audit
// ─────────────────────────────────────────────────────────────

model AuditEvent {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// App Configuration & Auth
// ─────────────────────────────────────────────────────────────

model AppConfig {
  id                          String   @id @default("default")
  otpEmailVerificationEnabled Boolean  @default(true)
  selfRegistrationEnabled     Boolean  @default(true)
  updatedAt                   DateTime @updatedAt
}

model AuthOtp {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}
