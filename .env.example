# Copy to .env and adjust for local development.
# Generate a strong secret for production (e.g. openssl rand -base64 32)

JWT_SECRET=dev-change-me-use-openssl-rand-base64-32-in-prod

# Use a PostgreSQL role that actually exists on your machine. If you see
# "role \"postgres\" does not exist", Homebrew Postgres often has no "postgres"
# user — use your macOS username instead, e.g. postgresql://myname@localhost:5432/school_compliance
# Create DB: createdb school_compliance
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/school_compliance

PORT=4000
FRONTEND_URL=http://localhost:5173

# Platform admin (created on startup + `npm run db:seed`)
ADMIN_EMAIL=admin@schoolcompliance.com
ADMIN_PASSWORD=Admin@123

# Sample school + staff + compliance when the database has no schools yet (set false to skip)
SEED_SAMPLE_DATA=true
DEMO_SCHOOL_NAME=Sunshine Preschool
# One password for all demo users (director, branch director, teacher, parent, students). Defaults to Admin@123 or ADMIN_PASSWORD.
# DEMO_PASSWORD=Admin@123
DEMO_DIRECTOR_EMAIL=director@demo.school
DEMO_BRANCH_DIRECTOR_EMAIL=branchdirector@demo.school
DEMO_TEACHER_EMAIL=teacher@demo.school
DEMO_PARENT_EMAIL=parent@demo.school
DEMO_STUDENT1_EMAIL=student1@demo.school
DEMO_STUDENT2_EMAIL=student2@demo.school

# For `npm run db:seed` on an empty database: create tables first (same as app dev)
DB_SYNC=true

# Optional: S3-compatible storage (required for presigned uploads if using S3 driver)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=
# S3_ENDPOINT=
