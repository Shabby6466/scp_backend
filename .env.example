# Copy to .env and adjust for local development.
# Generate a strong secret for production (e.g. openssl rand -base64 32)

JWT_SECRET=dev-change-me-use-openssl-rand-base64-32-in-prod

DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/school_compliance

PORT=4000
FRONTEND_URL=http://localhost:5173

